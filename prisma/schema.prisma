generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatar       String?
  xp           Int      @default(0)
  level        Int      @default(1)
  createdAt    DateTime @default(now())

  todos        Todo[]
  projects     Project[]
  habits       Habit[]
  activityLogs ActivityLog[]
  badges       Badge[]
  streaks      Streak[]
  apiKeys      ApiKey[]
  vaultItems   VaultItem[]
}

model Todo {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  priority    String    @default("medium") // low, medium, high
  tags        String    @default("[]") // JSON array
  dueDate     DateTime?
  isLifetime  Boolean   @default(false)
  progress    Int?      // for lifetime goals like "read 100 books" — current count
  progressMax Int?      // target count
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  status      String   @default("active") // active, on_hold, completed, archived
  progressPct Int      @default(0)
  color       String   @default("#8b5cf6") // purple default
  createdAt   DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id])
  milestones Milestone[]
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  order       Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Habit {
  id          String   @id @default(cuid())
  userId      String
  title       String
  type        String   @default("good") // good, bad
  icon        String   @default("⭐")
  frequency   String   @default("daily") // daily, weekly
  unit        String?  // null=boolean, "cups", "minutes", "pages", "reps", "km", etc.
  targetValue Float?   // target per day (e.g. 20 mins, 3 cups max for bad)
  createdAt   DateTime @default(now())

  user User      @relation(fields: [userId], references: [id])
  logs HabitLog[]
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  date      DateTime
  completed Boolean  @default(true)
  value     Float?   // numeric value (cups, minutes, etc.)
  notes     String?
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  content   String
  category  String   @default("general") // general, todo, habit, project, vault, system
  source    String   @default("manual") // manual, api, telegram
  tags      String   @default("[]") // JSON array
  xpEarned  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Badge {
  id        String   @id @default(cuid())
  userId    String
  badgeType String
  unlockedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, badgeType])
}

model Streak {
  id           String   @id @default(cuid())
  userId       String
  type         String   // login, habit_meditation, etc.
  currentCount Int      @default(0)
  bestCount    Int      @default(0)
  lastDate     DateTime?

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  keyHash   String
  label     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model VaultItem {
  id        String   @id @default(cuid())
  userId    String
  category  String   // subscription, insurance, vehicle, finance, health, document, contact, other
  title     String
  data      String   @default("{}") // JSON — category-specific fields
  tags      String   @default("[]") // JSON array
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id])
  reminders VaultReminder[]
}

model VaultReminder {
  id          String   @id @default(cuid())
  vaultItemId String
  remindAt    DateTime
  repeat      String   @default("none") // none, monthly, yearly, custom
  message     String?
  isActive    Boolean  @default(true)

  vaultItem VaultItem @relation(fields: [vaultItemId], references: [id], onDelete: Cascade)
}
