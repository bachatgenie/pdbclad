# ── Database ────────────────────────────────────────────────────
# PostgreSQL via Neon (free tier) — recommended for Vercel
# Get your connection string from: https://neon.tech → New Project → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx-yyy.region.aws.neon.tech/pdbclad?sslmode=require"

# ── Auth ─────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="your-secret-key-min-32-chars"

# Your app's public URL — no trailing slash
# Local:       http://localhost:3002
# Production:  https://dashboard.vibedash.uk
NEXTAUTH_URL="http://localhost:3002"

# ── Optional ─────────────────────────────────────────────────────
NODE_ENV="development"
